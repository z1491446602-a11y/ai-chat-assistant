PORT=3000

# Persistent storage paths for cloud deployment
STORAGE_DIR=/www/wwwroot/chat-app/storage
DATA_DIR=/www/wwwroot/chat-app/storage
DATA_FILE=/www/wwwroot/chat-app/storage/data.json
UPLOAD_DIR=/www/wwwroot/chat-app/storage/uploads
AUDIO_DIR=/www/wwwroot/chat-app/storage/audios
LEGACY_AUDIO_DIR=/www/wwwroot/chat-app/public/audios

# Public upload protection (20 MiB per file is enforced in code)
UPLOAD_MAX_TOTAL_BYTES=1073741824
UPLOAD_MAX_FILE_COUNT=5000
UPLOAD_RATE_LIMIT_WINDOW_MS=600000
UPLOAD_RATE_LIMIT_MAX=30

# Upstream chat model config
CHAT_API_URL=https://zyapi.tuluo.top:8888/v1/responses
CHAT_API_KEY=
CHAT_API_MODEL=gpt-5.4-mini
CHAT_ENABLE_WEB_SEARCH=true

# Optional Bocha web search used by chat
BOCHA_WEB_SEARCH_API_URL=https://api.bocha.cn/v1/web-search
BOCHA_WEB_SEARCH_API_KEY=
BOCHA_WEB_SEARCH_COUNT=5

# DeepSeek text model used by deepseek-v4 and voice text planning
DEEPSEEK_VOICE_CHAT_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_VOICE_CHAT_API_KEY=
DEEPSEEK_VOICE_CHAT_MODEL=deepseek-v4-flash

# MiMo chat and TTS
MIMO_CHAT_API_URL=https://token-plan-cn.xiaomimimo.com/v1/chat/completions
MIMO_CHAT_API_KEY=
MIMO_TTS_MODEL=mimo-v2.5-tts-voiceclone

# Optional custom image upstream; when enabled, set both an HTTPS URL and its key
IMAGE_API_URL=
IMAGE_API_KEY=
IMAGE_API_MODEL=gpt-image-2
# Optional: set a fixed size like 1024x1024 or 1536x1024; leave empty to let upstream decide the ratio
IMAGE_API_SIZE=

# AI chat image providers (server-side only)
IMAGE_DEFAULT_PROVIDER=gpt
IMAGE_GPT_GENERATION_URL=https://api.chancexj.com/v1/images/generations
IMAGE_GPT_EDIT_URL=https://api.chancexj.com/v1/images/edits
IMAGE_GPT_API_KEY=
IMAGE_GPT_MODEL=gpt-image-2
# Optional Grok image upstream; when enabled, set both HTTPS URLs and its key
IMAGE_GROK_GENERATION_URL=
IMAGE_GROK_EDIT_URL=
IMAGE_GROK_API_KEY=
IMAGE_GROK_MODEL=grok-imagine-image-quality

# AI video generation (server-side only)
VIDEO_DIR=/www/wwwroot/chat-app/storage/videos
VIDEO_API_URL=https://api.chancexj.com/v1/videos
VIDEO_API_KEY=
VIDEO_API_MODEL=veo_3_1_fast
VIDEO_POLL_INTERVAL_MS=10000
VIDEO_TIMEOUT_MS=600000
VIDEO_MAX_BYTES=209715200
VIDEO_DOWNLOAD_HOSTS=opcbucket.oss-cn-beijing.aliyuncs.com
FFPROBE_PATH=ffprobe

# Baidu speech-to-text
BAIDU_SPEECH_APP_ID=
BAIDU_SPEECH_API_KEY=
BAIDU_SPEECH_SECRET_KEY=
BAIDU_SPEECH_TOKEN_URL=https://aip.baidubce.com/oauth/2.0/token
BAIDU_SPEECH_ASR_URL=https://vop.baidu.com/server_api
BAIDU_SPEECH_DEV_PID=1537
